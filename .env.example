# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=Transcender

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/transcender?schema=public"
# SQLite (dev rápido): DATABASE_URL="file:./dev.db"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="access-secret-min-256bits"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="refresh-secret-min-256bits"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Email ─────────────────────────────────────────────────────────────────────
# Escolhe o provider: "resend" ou "smtp"
EMAIL_PROVIDER=smtp
EMAIL_FROM="Transcender <noreply@transcender.app>"

# Resend
RESEND_API_KEY="re_xxxxxxxxxxxx"

# SMTP (nodemailer) — descomenta se EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRES_SECONDS=300 # 5 minutos

# ── OAuth Providers ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
INTRA42_CLIENT_ID=
INTRA42_CLIENT_SECRET=

# ── Pino ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_PRETTY=true

# ── Webhook ───────────────────────────────────────────────────────────────────
WEBHOOK_SECRET="webhook-hmac-secret"
