{
  "name": "transcender",
  "version": "0.0.1",
  "description": "Transcender — NestJS 11 + DDD + Ports & Adapters",
  "author": "XLobe-Tech",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "tunnel": "npx cloudflared tunnel --url http://localhost:5000",
    "dev:tunnel": "concurrently \"npm run dev\" \"npm run tunnel\"",
    "prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "db:format": "prisma format",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "11.1.16",
    "@nestjs/config": "4.0.2",
    "@nestjs/core": "11.1.16",
    "@nestjs/devtools-integration": "^0.2.1",
    "@nestjs/event-emitter": "3.0.1",
    "@nestjs/jwt": "11.0.0",
    "@nestjs/platform-express": "11.1.16",
    "@nestjs/platform-socket.io": "11.1.16",
    "@nestjs/swagger": "11.2.6",
    "@nestjs/websockets": "11.1.16",
    "@prisma/client": "6.8.2",
    "bcryptjs": "2.4.3",
    "bullmq": "5.56.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "cookie-parser": "1.4.7",
    "nestjs-pino": "4.3.0",
    "nodemailer": "6.10.1",
    "pino": "9.6.0",
    "pino-http": "10.5.0",
    "pino-pretty": "13.0.0",
    "reflect-metadata": "0.2.2",
    "resend": "4.5.1",
    "rxjs": "7.8.2",
    "socket.io": "4.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.7",
    "@nestjs/schematics": "11.0.5",
    "@nestjs/testing": "11.1.16",
    "@types/bcryptjs": "2.4.6",
    "@types/cookie-parser": "1.4.8",
    "@types/express": "5.0.3",
    "@types/jest": "29.5.14",
    "@types/node": "22.15.21",
    "@types/nodemailer": "6.4.17",
    "@types/supertest": "6.0.3",
    "concurrently": "^9.2.1",
    "eslint": "9.28.0",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-prettier": "5.4.0",
    "jest": "29.7.0",
    "prettier": "3.5.3",
    "prisma": "6.8.2",
    "supertest": "7.1.0",
    "ts-jest": "29.3.4",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.33.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "@shared/(.*)": [
        "<rootDir>/shared/$1"
      ],
      "@common/(.*)": [
        "<rootDir>/common/$1"
      ],
      "@modules/(.*)": [
        "<rootDir>/modules/$1"
      ],
      "@config/(.*)": [
        "<rootDir>/config/$1"
      ]
    }
  }
}
